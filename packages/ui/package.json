{
  "name": "@lerno/ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*/index.d.ts",
      "svelte": "./dist/components/*/index.js",
      "default": "./dist/components/*/index.js"
    },
    "./utils.ts": {
      "types": "./dist/utils.d.ts",
      "svelte": "./dist/utils.js",
      "default": "./dist/utils.js"
    },
    "./constants/*": {
      "types": "./dist/constants/*.d.ts",
      "svelte": "./dist/constants/*.js",
      "default": "./dist/constants/*.js"
    },
    "./css": "./src/routes/layout.css"
  },
  "scripts": {
    "ui:add": "vpx shadcn-svelte@latest add",
    "dev": "vp dev",
    "build": "vp build && npm run prepack",
    "prepack": "svelte-kit sync && svelte-package",
    "preview": "vp preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "catalog:",
    "@internationalized/date": "catalog:",
    "@lucide/svelte": "catalog:",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/kit": "latest",
    "@sveltejs/package": "catalog:",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/forms": "latest",
    "@tailwindcss/typography": "latest",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/table-core": "catalog:",
    "bits-ui": "catalog:",
    "clsx": "catalog:",
    "embla-carousel-svelte": "catalog:",
    "formsnap": "catalog:",
    "layerchart": "catalog:",
    "mode-watcher": "catalog:",
    "paneforge": "catalog:",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "svelte-sonner": "catalog:",
    "sveltekit-superforms": "catalog:",
    "tailwind-merge": "catalog:",
    "tailwind-variants": "catalog:",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "catalog:",
    "typescript": "^5.9.3",
    "vaul-svelte": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  }
}