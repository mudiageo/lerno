{
  "name": "web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:e2e": "playwright test",
    "test": "npm run test:e2e",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "livekit-client": "catalog:",
    "livekit-server-sdk": "catalog:",
    "pg-boss": "catalog:"
  },
  "devDependencies": {
    "@better-auth/cli": "~1.4.21",
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^9.39.2",
    "@lerno/auth": "workspace:*",
    "@lerno/db": "workspace:*",
    "@lerno/jobs": "workspace:*",
    "@lerno/storage": "workspace:*",
    "@lerno/ui": "workspace:*",
    "@lucide/svelte": "catalog:",
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/svelte-query": "^5.65.0",
    "@types/node": "^24",
    "better-auth": "~1.4.21",
    "drizzle-kit": "catalog:",
    "drizzle-orm": "catalog:",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.14.0",
    "globals": "^17.3.0",
    "mode-watcher": "^1.1.0",
    "postgres": "^3.4.8",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.57.1",
    "valibot": "catalog:",
    "vite": "catalog:",
    "vite-plugin-devtools-json": "^1.0.0",
    "vite-plus": "catalog:"
  }
}
