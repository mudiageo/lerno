  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/lib/index.ts",
    "./components/*": "./src/lib/components/*",
    "./utils.ts": "./src/lib/utils.ts",
    "./app.css": "./src/app.css"
  },
  "scripts": {
    "ui:add": "vpx shadcn-svelte@latest add",
