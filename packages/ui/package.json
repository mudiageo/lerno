    "@tailwindcss/forms": "latest",
    "@tailwindcss/typography": "latest",
    "@tailwindcss/vite": "^4.1.18",
    "clsx": "catalog:",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "tailwind-merge": "catalog:",
    "tailwind-variants": "catalog:",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "catalog:",
