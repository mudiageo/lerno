{
  "name": "@lerno/auth",
  "version": "0.0.0",
  "description": "A starter for creating a TypeScript package.",
  "homepage": "https://github.com/author/library#readme",
  "bugs": {
    "url": "https://github.com/author/library/issues"
  },
  "license": "MIT",
  "author": "Author Name <author.name@mail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/author/library.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2"
  },
  "peerDependenciesMeta": {
    "@sveltejs/kit": {
      "optional": true
    }
  },
  "dependencies": {
    "@lerno/db": "workspace:*",
    "@lerno/email": "workspace:*",
    "better-auth": "^1.1.20"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "auth:schema": "auth generate --config ./src/index.ts --output ../db/src/schema/auth.tmp.ts --yes && tsx scripts/merge-schemas.ts",
    "prepublishOnly": "vp run build"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "auth": "catalog:",
    "bumpp": "^11.0.1",
    "typescript": "^5.9.3",
    "vite-plus": "^0.1.11"
  }
}